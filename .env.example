# Demo IMAP/SMTP Account (Mailtrap)
# Copy to .env and fill in real values for local development
VITE_DEMO_EMAIL=demo@mailtrap.io
VITE_DEMO_DISPLAY_NAME=Demo User
VITE_DEMO_IMAP_HOST=sandbox.smtp.mailtrap.io
VITE_DEMO_IMAP_PORT=993
VITE_DEMO_IMAP_SECURITY=ssl
VITE_DEMO_SMTP_HOST=sandbox.smtp.mailtrap.io
VITE_DEMO_SMTP_PORT=465
VITE_DEMO_SMTP_SECURITY=ssl
VITE_DEMO_USERNAME=
VITE_DEMO_PASSWORD=
